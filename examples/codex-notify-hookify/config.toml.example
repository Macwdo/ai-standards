#:schema https://developers.openai.com/codex/config-schema.json

# Copy this snippet into ~/.codex/config.toml and replace ABSOLUTE_PATH
# with the real path to this example directory.

notify = [
  "node",
  "ABSOLUTE_PATH/examples/codex-notify-hookify/notify-hook.js"
]

[features]
# The notify hook works without this flag. This is shown here only because
# current Codex builds also expose an under-development `codex_hooks` flag.
codex_hooks = true
